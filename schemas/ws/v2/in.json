{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://trucoshi.dev/schemas/ws/v2/in.json",
  "title": "Trucoshi WebSocket Protocol v2 — Inbound Frame (client -> server)",
  "type": "object",
  "required": [
    "msg",
    "v"
  ],
  "properties": {
    "id": {
      "description": "Optional correlation id (client sets; server echoes in responses).\n\nMissing: allowed. Explicit `null`: rejected.",
      "allOf": [
        {
          "$ref": "#/definitions/String"
        }
      ]
    },
    "msg": {
      "description": "Tagged payload.",
      "allOf": [
        {
          "$ref": "#/definitions/C2sMessage"
        }
      ]
    },
    "v": {
      "description": "Protocol version (must be exactly 2).",
      "allOf": [
        {
          "$ref": "#/definitions/WsVersion"
        }
      ]
    }
  },
  "additionalProperties": false,
  "definitions": {
    "C2sMessage": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "data",
            "type"
          ],
          "properties": {
            "data": {
              "$ref": "#/definitions/PingData"
            },
            "type": {
              "type": "string",
              "enum": [
                "ping"
              ]
            }
          },
          "additionalProperties": false
        },
        {
          "description": "Request a lobby snapshot.",
          "type": "object",
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "lobby.snapshot.get"
              ]
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "me.active_matches.get"
              ]
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "data",
            "type"
          ],
          "properties": {
            "data": {
              "$ref": "#/definitions/MatchCreateData"
            },
            "type": {
              "type": "string",
              "enum": [
                "match.create"
              ]
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "data",
            "type"
          ],
          "properties": {
            "data": {
              "$ref": "#/definitions/MatchJoinData"
            },
            "type": {
              "type": "string",
              "enum": [
                "match.join"
              ]
            }
          },
          "additionalProperties": false
        },
        {
          "description": "Join a match as a spectator (hands hidden; no seat).",
          "type": "object",
          "required": [
            "data",
            "type"
          ],
          "properties": {
            "data": {
              "$ref": "#/definitions/MatchWatchData"
            },
            "type": {
              "type": "string",
              "enum": [
                "match.watch"
              ]
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "data",
            "type"
          ],
          "properties": {
            "data": {
              "$ref": "#/definitions/MatchRefData"
            },
            "type": {
              "type": "string",
              "enum": [
                "match.leave"
              ]
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "data",
            "type"
          ],
          "properties": {
            "data": {
              "$ref": "#/definitions/MatchReadyData"
            },
            "type": {
              "type": "string",
              "enum": [
                "match.ready"
              ]
            }
          },
          "additionalProperties": false
        },
        {
          "description": "Fetch the current match snapshot by id (useful after reconnects).",
          "type": "object",
          "required": [
            "data",
            "type"
          ],
          "properties": {
            "data": {
              "$ref": "#/definitions/MatchRefData"
            },
            "type": {
              "type": "string",
              "enum": [
                "match.snapshot.get"
              ]
            }
          },
          "additionalProperties": false
        },
        {
          "description": "Fetch the current gameplay snapshot by match id.",
          "type": "object",
          "required": [
            "data",
            "type"
          ],
          "properties": {
            "data": {
              "$ref": "#/definitions/MatchRefData"
            },
            "type": {
              "type": "string",
              "enum": [
                "game.snapshot.get"
              ]
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "data",
            "type"
          ],
          "properties": {
            "data": {
              "$ref": "#/definitions/MatchRefData"
            },
            "type": {
              "type": "string",
              "enum": [
                "match.start"
              ]
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "data",
            "type"
          ],
          "properties": {
            "data": {
              "$ref": "#/definitions/MatchRefData"
            },
            "type": {
              "type": "string",
              "enum": [
                "match.pause"
              ]
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "data",
            "type"
          ],
          "properties": {
            "data": {
              "$ref": "#/definitions/MatchRefData"
            },
            "type": {
              "type": "string",
              "enum": [
                "match.resume"
              ]
            }
          },
          "additionalProperties": false
        },
        {
          "description": "Restart a finished match into a fresh lobby with the same players/teams.",
          "type": "object",
          "required": [
            "data",
            "type"
          ],
          "properties": {
            "data": {
              "$ref": "#/definitions/MatchRefData"
            },
            "type": {
              "type": "string",
              "enum": [
                "match.rematch"
              ]
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "data",
            "type"
          ],
          "properties": {
            "data": {
              "$ref": "#/definitions/MatchKickData"
            },
            "type": {
              "type": "string",
              "enum": [
                "match.kick"
              ]
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "data",
            "type"
          ],
          "properties": {
            "data": {
              "$ref": "#/definitions/ChatJoinData"
            },
            "type": {
              "type": "string",
              "enum": [
                "chat.join"
              ]
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "data",
            "type"
          ],
          "properties": {
            "data": {
              "$ref": "#/definitions/ChatSayData"
            },
            "type": {
              "type": "string",
              "enum": [
                "chat.say"
              ]
            }
          },
          "additionalProperties": false
        },
        {
          "description": "Gameplay: play a card.",
          "type": "object",
          "required": [
            "data",
            "type"
          ],
          "properties": {
            "data": {
              "$ref": "#/definitions/GamePlayCardData"
            },
            "type": {
              "type": "string",
              "enum": [
                "game.play_card"
              ]
            }
          },
          "additionalProperties": false
        },
        {
          "description": "Gameplay: say a command (truco/envido/flor/etc).",
          "type": "object",
          "required": [
            "data",
            "type"
          ],
          "properties": {
            "data": {
              "$ref": "#/definitions/GameSayData"
            },
            "type": {
              "type": "string",
              "enum": [
                "game.say"
              ]
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "ChatJoinData": {
      "type": "object",
      "required": [
        "room_id"
      ],
      "properties": {
        "room_id": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "ChatSayData": {
      "type": "object",
      "required": [
        "content",
        "room_id"
      ],
      "properties": {
        "content": {
          "type": "string"
        },
        "room_id": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "GameCommand": {
      "description": "Core gameplay commands (Truco argentino).",
      "type": "string",
      "enum": [
        "truco",
        "retruco",
        "vale_cuatro",
        "envido",
        "real_envido",
        "falta_envido",
        "flor",
        "contra_flor",
        "contra_flor_al_resto",
        "quiero",
        "no_quiero",
        "son_buenas"
      ]
    },
    "GamePlayCardData": {
      "type": "object",
      "required": [
        "card_idx",
        "match_id"
      ],
      "properties": {
        "card_idx": {
          "description": "`card_idx` references the caller's current hand ordering.\n\nMessage type: `game.play_card`",
          "type": "integer",
          "format": "uint8",
          "minimum": 0.0
        },
        "match_id": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "GameSayData": {
      "type": "object",
      "required": [
        "command",
        "match_id"
      ],
      "properties": {
        "command": {
          "$ref": "#/definitions/GameCommand"
        },
        "match_id": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "MatchCreateData": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "description": "Display name for the creating player.",
          "type": "string"
        },
        "options": {
          "description": "Match options.\n\nOptional: when omitted, the server uses defaults.",
          "allOf": [
            {
              "$ref": "#/definitions/MatchOptions"
            }
          ]
        },
        "team": {
          "description": "Optional requested team (0 or 1). Server may override if full.",
          "allOf": [
            {
              "$ref": "#/definitions/TeamIdx"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "MatchJoinData": {
      "type": "object",
      "required": [
        "match_id",
        "name"
      ],
      "properties": {
        "match_id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "team": {
          "description": "Optional requested team (0 or 1). Server may override if full.",
          "allOf": [
            {
              "$ref": "#/definitions/TeamIdx"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "MatchKickData": {
      "type": "object",
      "required": [
        "match_id",
        "seat_idx"
      ],
      "properties": {
        "match_id": {
          "type": "string"
        },
        "seat_idx": {
          "type": "integer",
          "format": "uint8",
          "minimum": 0.0
        }
      },
      "additionalProperties": false
    },
    "MatchOptions": {
      "type": "object",
      "required": [
        "flor",
        "match_points",
        "max_players",
        "turn_time_ms"
      ],
      "properties": {
        "abandon_time_ms": {
          "description": "Inactivity window before a disconnected player is removed.",
          "default": 120000,
          "type": "integer",
          "format": "int64",
          "maximum": 600000.0,
          "minimum": 1.0
        },
        "falta_envido": {
          "description": "Falta Envido scoring mode (`1` = two faltas / 2 × `match_points`, `2` = one falta / `match_points`).",
          "default": 2,
          "type": "integer",
          "format": "uint8",
          "maximum": 2.0,
          "minimum": 1.0
        },
        "flor": {
          "description": "Whether Flor is enabled.",
          "type": "boolean"
        },
        "match_points": {
          "description": "Points required to win the match.",
          "type": "integer",
          "format": "uint8",
          "maximum": 15.0,
          "minimum": 1.0
        },
        "max_players": {
          "description": "Maximum number of players allowed in the match.\n\nProtocol v2: enforced as an explicit enum (2/4/6), since Truco is always two teams with equal sizes.",
          "type": "integer",
          "format": "uint8",
          "enum": [
            2,
            4,
            6
          ]
        },
        "reconnect_grace_ms": {
          "description": "Minimum grace after a websocket drop before sweeps run.",
          "default": 5000,
          "type": "integer",
          "format": "int64",
          "maximum": 60000.0,
          "minimum": 1.0
        },
        "turn_time_ms": {
          "description": "Turn timer in milliseconds.",
          "type": "integer",
          "format": "int64",
          "maximum": 600000.0,
          "minimum": 1.0
        }
      },
      "additionalProperties": false
    },
    "MatchReadyData": {
      "type": "object",
      "required": [
        "match_id",
        "ready"
      ],
      "properties": {
        "match_id": {
          "type": "string"
        },
        "ready": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "MatchRefData": {
      "type": "object",
      "required": [
        "match_id"
      ],
      "properties": {
        "match_id": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "MatchWatchData": {
      "description": "Join a match as a spectator (does not occupy a player seat).",
      "type": "object",
      "required": [
        "match_id"
      ],
      "properties": {
        "match_id": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "PingData": {
      "type": "object",
      "required": [
        "client_time_ms"
      ],
      "properties": {
        "client_time_ms": {
          "type": "integer",
          "format": "int64"
        }
      },
      "additionalProperties": false
    },
    "String": {
      "type": "string"
    },
    "TeamIdx": {
      "type": "integer",
      "format": "uint8",
      "enum": [
        0,
        1
      ],
      "maximum": 1.0,
      "minimum": 0.0
    },
    "WsVersion": {
      "type": "integer",
      "const": 2,
      "maximum": 2.0,
      "minimum": 2.0
    }
  }
}