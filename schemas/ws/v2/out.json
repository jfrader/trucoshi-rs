{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://trucoshi.dev/schemas/ws/v2/out.json",
  "title": "Trucoshi WebSocket Protocol v2 — Outbound Frame (server -> client)",
  "type": "object",
  "required": [
    "msg",
    "v"
  ],
  "properties": {
    "id": {
      "description": "Optional correlation id (client sets; server echoes in responses).\n\nMissing: allowed. Explicit `null`: rejected.",
      "allOf": [
        {
          "$ref": "#/definitions/String"
        }
      ]
    },
    "msg": {
      "description": "Tagged payload.",
      "allOf": [
        {
          "$ref": "#/definitions/S2cMessage"
        }
      ]
    },
    "v": {
      "description": "Protocol version (must be exactly 2).",
      "allOf": [
        {
          "$ref": "#/definitions/WsVersion"
        }
      ]
    }
  },
  "additionalProperties": false,
  "definitions": {
    "ActiveMatchPlayer": {
      "type": "object",
      "required": [
        "is_owner",
        "last_active_ms",
        "ready",
        "seat_idx",
        "team"
      ],
      "properties": {
        "disconnected_at_ms": {
          "$ref": "#/definitions/int64"
        },
        "is_owner": {
          "type": "boolean"
        },
        "last_active_ms": {
          "type": "integer",
          "format": "int64"
        },
        "ready": {
          "type": "boolean"
        },
        "seat_idx": {
          "type": "integer",
          "format": "uint8",
          "minimum": 0.0
        },
        "team": {
          "$ref": "#/definitions/TeamIdx"
        }
      },
      "additionalProperties": false
    },
    "ActiveMatchSummary": {
      "type": "object",
      "required": [
        "match",
        "me"
      ],
      "properties": {
        "match": {
          "$ref": "#/definitions/PublicMatch"
        },
        "me": {
          "$ref": "#/definitions/ActiveMatchPlayer"
        }
      },
      "additionalProperties": false
    },
    "ActiveMatchesSnapshotData": {
      "type": "object",
      "required": [
        "matches"
      ],
      "properties": {
        "matches": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ActiveMatchSummary"
          }
        }
      },
      "additionalProperties": false
    },
    "ChatMessageData": {
      "type": "object",
      "required": [
        "message",
        "room_id"
      ],
      "properties": {
        "message": {
          "$ref": "#/definitions/PublicChatMessage"
        },
        "room_id": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "ChatSnapshotData": {
      "type": "object",
      "required": [
        "room"
      ],
      "properties": {
        "room": {
          "$ref": "#/definitions/PublicChatRoom"
        }
      },
      "additionalProperties": false
    },
    "ErrorPayload": {
      "type": "object",
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "description": "Machine-readable error code.",
          "type": "string"
        },
        "message": {
          "description": "Human-readable error message.\n\nProtocol v2 is strict: this field is always present.",
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "GameCommand": {
      "description": "Core gameplay commands (Truco argentino).",
      "type": "string",
      "enum": [
        "truco",
        "retruco",
        "vale_cuatro",
        "envido",
        "real_envido",
        "falta_envido",
        "flor",
        "contra_flor",
        "contra_flor_al_resto",
        "quiero",
        "no_quiero",
        "son_buenas"
      ]
    },
    "GameSnapshotData": {
      "type": "object",
      "required": [
        "game",
        "match_id"
      ],
      "properties": {
        "game": {
          "$ref": "#/definitions/PublicGameState"
        },
        "match_id": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "GameUpdateData": {
      "type": "object",
      "required": [
        "game",
        "match_id"
      ],
      "properties": {
        "game": {
          "$ref": "#/definitions/PublicGameState"
        },
        "match_id": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "HandState": {
      "description": "Gameplay hand state hints.",
      "type": "string",
      "enum": [
        "waiting_play",
        "waiting_for_truco_answer",
        "waiting_envido_answer",
        "waiting_envido_points_answer",
        "waiting_flor_answer",
        "display_flor_battle",
        "display_previous_hand",
        "finished"
      ]
    },
    "HelloData": {
      "type": "object",
      "required": [
        "server_version",
        "session_id"
      ],
      "properties": {
        "server_version": {
          "type": "string"
        },
        "session_id": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "LobbyMatch": {
      "description": "Lobby match summary (protocol v2).\n\nThis is intentionally minimal and is the only match type used by lobby events. It should stay stable and UI-friendly.\n\nNote: we intentionally duplicate fields between `LobbyMatch` and `PublicMatch` instead of using a `flatten`ed base struct. This keeps Rust-side ergonomics simple and avoids schema/ generator edge-cases.",
      "type": "object",
      "required": [
        "id",
        "options",
        "owner_seat_idx",
        "phase",
        "players",
        "spectator_count"
      ],
      "properties": {
        "id": {
          "description": "Match id (opaque).",
          "type": "string"
        },
        "options": {
          "$ref": "#/definitions/MatchOptions"
        },
        "owner_seat_idx": {
          "description": "Seat index (in `players[]`) of the current match owner.",
          "type": "integer",
          "format": "uint8",
          "minimum": 0.0
        },
        "phase": {
          "$ref": "#/definitions/MatchPhase"
        },
        "players": {
          "description": "Players ordered by seating/turn order (server-defined).",
          "type": "array",
          "items": {
            "$ref": "#/definitions/PublicPlayer"
          }
        },
        "spectator_count": {
          "description": "Number of currently connected spectator (watch) sessions.",
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        }
      },
      "additionalProperties": false
    },
    "LobbyMatchRemoveData": {
      "type": "object",
      "required": [
        "match_id"
      ],
      "properties": {
        "match_id": {
          "description": "Match id (same value as `PublicMatch.id`).",
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "LobbyMatchUpsertData": {
      "type": "object",
      "required": [
        "match"
      ],
      "properties": {
        "match": {
          "$ref": "#/definitions/LobbyMatch"
        }
      },
      "additionalProperties": false
    },
    "LobbySnapshotData": {
      "type": "object",
      "required": [
        "matches"
      ],
      "properties": {
        "matches": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/LobbyMatch"
          }
        }
      },
      "additionalProperties": false
    },
    "MatchKickedData": {
      "type": "object",
      "required": [
        "match_id",
        "reason"
      ],
      "properties": {
        "match_id": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "MatchLeftData": {
      "description": "Confirmation that the client has left a match.\n\nThis exists so `match.leave` does not need any legacy-style \"ok\" quirks.",
      "type": "object",
      "required": [
        "match_id"
      ],
      "properties": {
        "match_id": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "MatchOptions": {
      "type": "object",
      "required": [
        "flor",
        "match_points",
        "max_players",
        "turn_time_ms"
      ],
      "properties": {
        "abandon_time_ms": {
          "description": "Inactivity window before a disconnected player is removed.",
          "default": 120000,
          "type": "integer",
          "format": "int64",
          "maximum": 600000.0,
          "minimum": 1.0
        },
        "falta_envido": {
          "description": "Falta Envido scoring mode (`1` = two faltas / 2 × `match_points`, `2` = one falta / `match_points`).",
          "default": 2,
          "type": "integer",
          "format": "uint8",
          "maximum": 2.0,
          "minimum": 1.0
        },
        "flor": {
          "description": "Whether Flor is enabled.",
          "type": "boolean"
        },
        "match_points": {
          "description": "Points required to win the match.",
          "type": "integer",
          "format": "uint8",
          "maximum": 15.0,
          "minimum": 1.0
        },
        "max_players": {
          "description": "Maximum number of players allowed in the match.\n\nProtocol v2: enforced as an explicit enum (2/4/6), since Truco is always two teams with equal sizes.",
          "type": "integer",
          "format": "uint8",
          "enum": [
            2,
            4,
            6
          ]
        },
        "reconnect_grace_ms": {
          "description": "Minimum grace after a websocket drop before sweeps run.",
          "default": 5000,
          "type": "integer",
          "format": "int64",
          "maximum": 60000.0,
          "minimum": 1.0
        },
        "turn_time_ms": {
          "description": "Turn timer in milliseconds.",
          "type": "integer",
          "format": "int64",
          "maximum": 600000.0,
          "minimum": 1.0
        }
      },
      "additionalProperties": false
    },
    "MatchPhase": {
      "type": "string",
      "enum": [
        "lobby",
        "started",
        "paused",
        "finished"
      ]
    },
    "MatchSnapshotData": {
      "type": "object",
      "required": [
        "match"
      ],
      "properties": {
        "match": {
          "$ref": "#/definitions/PublicMatch"
        },
        "me": {
          "$ref": "#/definitions/PrivatePlayer"
        }
      },
      "additionalProperties": false
    },
    "MatchUpdateData": {
      "type": "object",
      "required": [
        "match"
      ],
      "properties": {
        "match": {
          "$ref": "#/definitions/PublicMatch"
        },
        "me": {
          "$ref": "#/definitions/PrivatePlayer"
        }
      },
      "additionalProperties": false
    },
    "PlayedCard": {
      "type": "object",
      "required": [
        "card",
        "seat_idx"
      ],
      "properties": {
        "card": {
          "type": "string"
        },
        "seat_idx": {
          "type": "integer",
          "format": "uint8",
          "minimum": 0.0
        }
      },
      "additionalProperties": false
    },
    "PongData": {
      "type": "object",
      "required": [
        "client_time_ms",
        "server_time_ms"
      ],
      "properties": {
        "client_time_ms": {
          "type": "integer",
          "format": "int64"
        },
        "server_time_ms": {
          "type": "integer",
          "format": "int64"
        }
      },
      "additionalProperties": false
    },
    "PrivatePlayer": {
      "description": "Recipient-only private view of the current player.",
      "type": "object",
      "required": [
        "commands",
        "envido_points",
        "hand",
        "has_flor",
        "seat_idx",
        "used"
      ],
      "properties": {
        "commands": {
          "description": "Commands the player is currently allowed to say.\n\nProtocol v2 is intentionally strict: this is a typed enum instead of free-form strings.",
          "type": "array",
          "items": {
            "$ref": "#/definitions/GameCommand"
          }
        },
        "envido_points": {
          "type": "integer",
          "format": "int32"
        },
        "hand": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "has_flor": {
          "type": "boolean"
        },
        "seat_idx": {
          "description": "Seat index in the match's current `players` ordering.",
          "type": "integer",
          "format": "uint8",
          "minimum": 0.0
        },
        "used": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "PublicChatMessage": {
      "type": "object",
      "required": [
        "content",
        "date_ms",
        "id",
        "system",
        "user"
      ],
      "properties": {
        "content": {
          "type": "string"
        },
        "date_ms": {
          "description": "Epoch millis.",
          "type": "integer",
          "format": "int64"
        },
        "id": {
          "type": "string"
        },
        "system": {
          "description": "Whether the message is system-generated.\n\nProtocol v2 is strict: this field is always present (use `false` for normal messages).",
          "type": "boolean"
        },
        "user": {
          "$ref": "#/definitions/PublicChatUser"
        }
      },
      "additionalProperties": false
    },
    "PublicChatRoom": {
      "type": "object",
      "required": [
        "id",
        "messages"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "messages": {
          "description": "Recent chat messages for the room (may be empty, but is always present).",
          "type": "array",
          "items": {
            "$ref": "#/definitions/PublicChatMessage"
          }
        }
      },
      "additionalProperties": false
    },
    "PublicChatUser": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "seat_idx": {
          "description": "Optional match seat index, if the sender is currently in a match.",
          "allOf": [
            {
              "$ref": "#/definitions/uint8"
            }
          ]
        },
        "team": {
          "$ref": "#/definitions/TeamIdx"
        }
      },
      "additionalProperties": false
    },
    "PublicGameState": {
      "description": "Minimal public game state (protocol v2).\n\nThis mirrors `trucoshi_game::PublicGameState` but uses `Maybe<T>` for optional fields.",
      "type": "object",
      "required": [
        "forehand_seat_idx",
        "hand_state",
        "rounds",
        "turn_seat_idx"
      ],
      "properties": {
        "forehand_seat_idx": {
          "type": "integer",
          "format": "uint8",
          "minimum": 0.0
        },
        "hand_state": {
          "$ref": "#/definitions/HandState"
        },
        "rounds": {
          "description": "Played cards grouped by round/trick.",
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/definitions/PlayedCard"
            }
          }
        },
        "turn_seat_idx": {
          "type": "integer",
          "format": "uint8",
          "minimum": 0.0
        },
        "winner_team_idx": {
          "description": "When set, the current hand is finished and the winner team is known.",
          "allOf": [
            {
              "$ref": "#/definitions/TeamIdx"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "PublicMatch": {
      "description": "Public match snapshot (protocol v2).\n\nThis is the authoritative match state used by match-scoped events.",
      "type": "object",
      "required": [
        "id",
        "options",
        "owner_seat_idx",
        "phase",
        "players",
        "spectator_count",
        "team_points"
      ],
      "properties": {
        "id": {
          "description": "Match id (opaque).",
          "type": "string"
        },
        "options": {
          "$ref": "#/definitions/MatchOptions"
        },
        "owner_seat_idx": {
          "description": "Seat index (in `players[]`) of the current match owner.",
          "type": "integer",
          "format": "uint8",
          "minimum": 0.0
        },
        "pause_request": {
          "$ref": "#/definitions/PublicPauseRequest"
        },
        "pending_unpause": {
          "$ref": "#/definitions/PublicPendingUnpause"
        },
        "phase": {
          "$ref": "#/definitions/MatchPhase"
        },
        "players": {
          "description": "Players ordered by seating/turn order (server-defined).",
          "type": "array",
          "items": {
            "$ref": "#/definitions/PublicPlayer"
          }
        },
        "spectator_count": {
          "description": "Number of currently connected spectator (watch) sessions.",
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "team_points": {
          "description": "Current match points for teams 0 and 1.",
          "type": "array",
          "items": {
            "type": "integer",
            "format": "uint8",
            "minimum": 0.0
          },
          "maxItems": 2,
          "minItems": 2
        }
      },
      "additionalProperties": false
    },
    "PublicPauseRequest": {
      "description": "Pending pause request metadata exposed in `PublicMatch`.",
      "type": "object",
      "required": [
        "awaiting_team",
        "expires_at_ms",
        "requested_by_seat_idx",
        "requested_by_team"
      ],
      "properties": {
        "awaiting_team": {
          "$ref": "#/definitions/TeamIdx"
        },
        "expires_at_ms": {
          "type": "integer",
          "format": "int64"
        },
        "requested_by_seat_idx": {
          "type": "integer",
          "format": "uint8",
          "minimum": 0.0
        },
        "requested_by_team": {
          "$ref": "#/definitions/TeamIdx"
        }
      },
      "additionalProperties": false
    },
    "PublicPendingUnpause": {
      "description": "Pending unpause countdown metadata.",
      "type": "object",
      "required": [
        "resume_at_ms"
      ],
      "properties": {
        "resume_at_ms": {
          "type": "integer",
          "format": "int64"
        }
      },
      "additionalProperties": false
    },
    "PublicPlayer": {
      "description": "Public player view (protocol v2).\n\nThis is designed to be minimal and UI-friendly: - The players array ordering is server-defined and stable for the lifetime of the match. - `ready` is per-player (no separate match-level ready list) - Match ownership is exposed at the match level via `owner_seat_idx`.\n\nNote: player keys are server-internal (session-bound) and are intentionally not exposed.",
      "type": "object",
      "required": [
        "name",
        "ready",
        "team"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "ready": {
          "type": "boolean"
        },
        "team": {
          "$ref": "#/definitions/TeamIdx"
        }
      },
      "additionalProperties": false
    },
    "S2cMessage": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "data",
            "type"
          ],
          "properties": {
            "data": {
              "$ref": "#/definitions/PongData"
            },
            "type": {
              "type": "string",
              "enum": [
                "pong"
              ]
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "data",
            "type"
          ],
          "properties": {
            "data": {
              "$ref": "#/definitions/HelloData"
            },
            "type": {
              "type": "string",
              "enum": [
                "hello"
              ]
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "data",
            "type"
          ],
          "properties": {
            "data": {
              "$ref": "#/definitions/ActiveMatchesSnapshotData"
            },
            "type": {
              "type": "string",
              "enum": [
                "me.active_matches"
              ]
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "data",
            "type"
          ],
          "properties": {
            "data": {
              "$ref": "#/definitions/LobbySnapshotData"
            },
            "type": {
              "type": "string",
              "enum": [
                "lobby.snapshot"
              ]
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "data",
            "type"
          ],
          "properties": {
            "data": {
              "$ref": "#/definitions/LobbyMatchUpsertData"
            },
            "type": {
              "type": "string",
              "enum": [
                "lobby.match.upsert"
              ]
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "data",
            "type"
          ],
          "properties": {
            "data": {
              "$ref": "#/definitions/LobbyMatchRemoveData"
            },
            "type": {
              "type": "string",
              "enum": [
                "lobby.match.remove"
              ]
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "data",
            "type"
          ],
          "properties": {
            "data": {
              "$ref": "#/definitions/MatchSnapshotData"
            },
            "type": {
              "type": "string",
              "enum": [
                "match.snapshot"
              ]
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "data",
            "type"
          ],
          "properties": {
            "data": {
              "$ref": "#/definitions/MatchUpdateData"
            },
            "type": {
              "type": "string",
              "enum": [
                "match.update"
              ]
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "data",
            "type"
          ],
          "properties": {
            "data": {
              "$ref": "#/definitions/MatchLeftData"
            },
            "type": {
              "type": "string",
              "enum": [
                "match.left"
              ]
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "data",
            "type"
          ],
          "properties": {
            "data": {
              "$ref": "#/definitions/MatchKickedData"
            },
            "type": {
              "type": "string",
              "enum": [
                "match.kicked"
              ]
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "data",
            "type"
          ],
          "properties": {
            "data": {
              "$ref": "#/definitions/GameSnapshotData"
            },
            "type": {
              "type": "string",
              "enum": [
                "game.snapshot"
              ]
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "data",
            "type"
          ],
          "properties": {
            "data": {
              "$ref": "#/definitions/GameUpdateData"
            },
            "type": {
              "type": "string",
              "enum": [
                "game.update"
              ]
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "data",
            "type"
          ],
          "properties": {
            "data": {
              "$ref": "#/definitions/ChatSnapshotData"
            },
            "type": {
              "type": "string",
              "enum": [
                "chat.snapshot"
              ]
