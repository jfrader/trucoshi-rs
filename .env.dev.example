# Used by docker-compose.dev.yml (copy to .env.dev if you want)

APP_ENV=development
APP_ADDR=0.0.0.0:2992
PUBLIC_BASE_URL=http://localhost:2992

DATABASE_URL=postgres://postgres:postgres@db:5432/trucoshi

# For dev: any string is accepted; server attempts base64 decode then falls back to raw bytes.
JWT_SECRET=dev-secret-change-me
JWT_ISSUER=trucoshi
JWT_AUDIENCE=trucoshi

TWITTER_CLIENT_ID=TODO
TWITTER_CLIENT_SECRET=TODO

# Optional SMTP settings (leave blank to disable email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=
